{
  "name": "a-lang-syntax",
  "displayName": "a-lang Syntax",
  "description": "Syntax highlighting and language configuration for a-lang.",
  "version": "0.0.1",
  "publisher": "sergeyd",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "a-lang",
        "aliases": [
          "a-lang",
          "a"
        ],
        "extensions": [
          ".al"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "a-lang",
        "scopeName": "source.a-lang",
        "path": "./syntaxes/a-lang.tmLanguage.json"
      }
    ]
  }
}
